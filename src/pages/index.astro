                                    class="grid grid-rows-[0fr] opacity-0 group-hover:grid-rows-[1fr] group-focus:grid-rows-[1fr] group-hover:opacity-100 group-focus:opacity-100 group-hover:mt-3 group-focus:mt-3 transition-[grid-template-rows,opacity,margin] duration-500 ease-in-out"
                                >
