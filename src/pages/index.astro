                                            Ingeniería de flujos y
                                            sincronización de datos para
                                            conciertos y espectáculos masivos
                                            con registro simultáneo de múltiples
                                            cámaras.
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </article>
                    </div>
                </div>
            </section>

            <section
                id="portfolio-cta"
                class="py-24 px-8 md:px-24 max-w-5xl mx-auto border-b border-zinc-900/60 text-center md:text-left"
            >
                <h2
                    class="text-xs uppercase tracking-[0.3em] text-zinc-500 font-mono mb-6"
                >
                    // Portafolio
                </h2>
                <h3
                    class="text-xl md:text-3xl font-light text-zinc-300 mb-8 max-w-2xl leading-relaxed"
                >
                    Mira nuestro Showreel y el registro de trabajos en Cine,
                    Publicidad, Video Clips y Shows en Vivo.
                </h3>

                <!-- Showreel Video Player (DIT Monitor / Viewfinder Style) -->
                <div
                    id="showreel-monitor"
                    class="relative w-full aspect-video rounded-sm overflow-hidden border border-zinc-800 bg-zinc-950/80 mb-12 group/reel cursor-pointer shadow-2xl"
                >
                    <!-- Viewfinder Grid & Overlays (DIT/Cinematic style) -->
                    <div id="viewfinder-overlays" class="absolute inset-0 pointer-events-none p-4 flex flex-col justify-between font-mono text-[9px] md:text-xs text-zinc-500 z-10 transition-opacity duration-500">
                        <!-- Top row: REC, TC, Frame Rate -->
                        <div class="flex justify-between items-center w-full">
                            <div class="flex items-center gap-2">
                                <span class="inline-block w-2 h-2 rounded-full bg-red-600 animate-pulse"></span>
                                <span class="tracking-widest font-semibold text-zinc-300">REC</span>
                            </div>
                            <div class="tracking-widest font-semibold text-zinc-400">TC 00:01:24:12</div>
                            <div class="tracking-widest">23.976 FPS</div>
                        </div>
                        <!-- Center Crosshair -->
                        <div class="absolute inset-0 flex items-center justify-center opacity-10 pointer-events-none">
                            <div class="w-8 h-px bg-white"></div>
                            <div class="h-8 w-px bg-white absolute"></div>
                        </div>
                        <!-- Bottom row: Resolution, Reel name, status -->
                        <div class="flex justify-between items-center w-full">
                            <div class="tracking-wider">ARRIRAW // 4.6K</div>
                            <div class="tracking-wider text-zinc-400">FELO_RF_REEL_2026.MOV</div>
                            <div class="tracking-wider">100% OK</div>
                        </div>
                    </div>

                    <!-- Inner Container with subtle glow and scanline effect -->
                    <div
                        id="play-overlay"
                        class="absolute inset-0 bg-gradient-to-tr from-zinc-950 via-zinc-900 to-zinc-950 flex flex-col items-center justify-center transition-opacity duration-500 z-0"
                    >
                        <!-- Play Button Overlay -->
                        <div
                            class="relative z-20 flex flex-col items-center gap-4 transition-transform duration-500 group-hover/reel:scale-105"
                        >
                            <div
                                class="w-16 h-16 rounded-full border border-amber-500/30 bg-amber-500/10 flex items-center justify-center text-amber-500 shadow-[0_0_20px_rgba(245,158,11,0.15)] group-hover/reel:bg-amber-500 group-hover/reel:text-black group-hover/reel:border-amber-500 transition-all duration-300"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    fill="currentColor"
                                    viewBox="0 0 24 24"
                                    class="w-6 h-6 translate-x-[2px]"
                                >
                                    <path d="M8 5v14l11-7z"></path>
                                </svg>
                            </div>
                            <span
                                class="text-xs uppercase tracking-[0.25em] font-mono text-zinc-400 group-hover/reel:text-amber-500 transition-colors duration-300"
                                >PROYECTAR SHOWREEL</span
                            >
                        </div>
                    </div>

                    <!-- Video Container for iframe -->
                    <div id="video-container" class="absolute inset-0 w-full h-full hidden"></div>
                </div>

                <a
                    href="/reel"
                    class="inline-block border bg-zinc-900/40 text-amber-500 animate-border-glow hover:bg-amber-500 hover:text-black font-mono text-sm md:text-base font-bold uppercase tracking-widest px-12 py-6 mt-8 rounded-sm transition-all duration-300 shadow-xl"
                >
                    Ver Historial de Proyectos // _
                </a>
            </section>

            <section
                id="contacto"
                class="py-24 px-8 md:px-24 max-w-5xl mx-auto text-center md:text-left"
            >
                <h2
                    class="text-2xl md:text-4xl font-bold tracking-tight mb-4 text-zinc-100"
                >
                    ¿Tienes un rodaje o show en vivo en camino?
                </h2>
                <p class="text-zinc-500 max-w-xl mb-8 font-light">
                    Asegura la integridad de tu material digital desde el primer
                    "acción" en el set hasta la entrega final en postproducción.
                </p>
                <a
                    href="mailto:datafelo@gmail.com"
                    class="inline-block border border-zinc-700 bg-zinc-900/40 hover:bg-white hover:text-black hover:border-white font-mono text-xs uppercase tracking-widest px-8 py-4 rounded-sm transition-all duration-300"
                >
                    Hablemos // _
                </a>
            </section>
        </main>

        <footer
            class="border-t border-zinc-900/40 py-8 text-center text-xs text-zinc-600 font-mono"
        >
            <p>
                &copy; 2026 FELO_RF By Red Flowers Soluciones Audiovisuales.
                Todos los derechos reservados.
            </p>
        </footer>
        <script>
            const monitor = document.getElementById('showreel-monitor');
            const playOverlay = document.getElementById('play-overlay');
            const overlays = document.getElementById('viewfinder-overlays');
            const videoContainer = document.getElementById('video-container');

            if (monitor && playOverlay && overlays && videoContainer) {
                monitor.addEventListener('click', () => {
                    // Hide overlays with CSS transition
                    playOverlay.classList.add('opacity-0');
                    overlays.classList.add('opacity-0');
                    
                    // Wait for fade out transition (500ms), then load iframe
                    setTimeout(() => {
                        playOverlay.classList.add('hidden');
                        overlays.classList.add('hidden');
                        videoContainer.classList.remove('hidden');
                        videoContainer.innerHTML = `
                            <iframe 
                                class="w-full h-full" 
                                src="https://www.youtube.com/embed/vXviav24ZEI?autoplay=1&modestbranding=1&rel=0" 
                                title="FELO_RF Showreel" 
                                frameborder="0" 
                                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
                                allowfullscreen
                            ></iframe>
                        `;
                    }, 500);
                }, { once: true });
            }
        </script>
    </body>
</html>
